# Frontend (Vite)
# API base URL for the Flask backend. Defaults to http://localhost:5000 if not set.
VITE_API_URL=http://localhost:5000

# Backend (Flask)
# Comma-separated allowed CORS origins. Defaults to http://localhost:5173
# CORS_ORIGINS=http://localhost:5173
# Path to FastF1 cache directory. Defaults to backend/cache/
# FASTF1_CACHE_DIR=./cache

# Google Gemini API Key (required for AI Insights)
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_api_key_here
